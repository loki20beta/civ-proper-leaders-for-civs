<?xml version="1.0" encoding="utf-8"?>
<Mod id="authentic-leaders" version="1" xmlns="ModInfo">

  <Properties>
    <Name>Authentic Leaders</Name>
    <Description>Replaces leader loading screen images and icons with civilization-specific artwork for a more historically authentic experience.</Description>
    <Authors>Custom</Authors>
    <AffectsSavedGames>0</AffectsSavedGames>
    <ShowInBrowser>1</ShowInBrowser>
    <EnabledByDefault>1</EnabledByDefault>
  </Properties>

  <Dependencies>
    <Mod id="base-standard" title="LOC_MODULE_BASE_STANDARD_NAME"/>
  </Dependencies>

  <ActionCriteria>
    <Criteria id="always">
      <AlwaysMet/>
    </Criteria>
  </ActionCriteria>

  <ActionGroups>
    <!-- Shell scope: icons visible in leader select / main menu -->
    <ActionGroup id="authentic-leaders-shell" scope="shell" criteria="always">
      <Properties>
        <LoadOrder>200</LoadOrder>
      </Properties>
      <Actions>
        <ImportFiles>
          <Item>icons/augustus/lp_circ_augustus_128.png</Item>
          <Item>icons/augustus/lp_circ_augustus_256.png</Item>
          <Item>icons/augustus/lp_circ_augustus_64.png</Item>
          <Item>icons/augustus/lp_hex_augustus_128.png</Item>
          <Item>icons/augustus/lp_hex_augustus_128_a.png</Item>
          <Item>icons/augustus/lp_hex_augustus_128_h.png</Item>
          <Item>icons/augustus/lp_hex_augustus_256.png</Item>
          <Item>icons/augustus/lp_hex_augustus_64.png</Item>
        </ImportFiles>
        <UpdateIcons>
          <Item>icons/leader-icons-override.xml</Item>
        </UpdateIcons>
      </Actions>
    </ActionGroup>

    <!-- Game scope: loading screen images + in-game icons + JS sort fix -->
    <ActionGroup id="authentic-leaders-game" scope="game" criteria="always">
      <Properties>
        <LoadOrder>200</LoadOrder>
      </Properties>
      <Actions>
        <ImportFiles>
          <!-- Leader icons (default) -->
          <Item>icons/augustus/lp_circ_augustus_128.png</Item>
          <Item>icons/augustus/lp_circ_augustus_256.png</Item>
          <Item>icons/augustus/lp_circ_augustus_64.png</Item>
          <Item>icons/augustus/lp_hex_augustus_128.png</Item>
          <Item>icons/augustus/lp_hex_augustus_128_a.png</Item>
          <Item>icons/augustus/lp_hex_augustus_128_h.png</Item>
          <Item>icons/augustus/lp_hex_augustus_256.png</Item>
          <Item>icons/augustus/lp_hex_augustus_64.png</Item>
          <!-- Leader icons (civ-specific: aksum) -->
          <Item>icons/augustus/aksum/lp_circ_augustus_aksum_128.png</Item>
          <Item>icons/augustus/aksum/lp_circ_augustus_aksum_256.png</Item>
          <Item>icons/augustus/aksum/lp_circ_augustus_aksum_64.png</Item>
          <Item>icons/augustus/aksum/lp_hex_augustus_aksum_128.png</Item>
          <Item>icons/augustus/aksum/lp_hex_augustus_aksum_128_a.png</Item>
