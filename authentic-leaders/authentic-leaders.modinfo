          <Item>icons/augustus/assyria/lp_circ_augustus_assyria_256.png</Item>
          <Item>icons/augustus/assyria/lp_circ_augustus_assyria_64.png</Item>
          <Item>icons/augustus/assyria/lp_hex_augustus_assyria_128.png</Item>
          <Item>icons/augustus/assyria/lp_hex_augustus_assyria_128_a.png</Item>
          <Item>icons/augustus/assyria/lp_hex_augustus_assyria_128_h.png</Item>
          <Item>icons/augustus/assyria/lp_hex_augustus_assyria_256.png</Item>
          <Item>icons/augustus/assyria/lp_hex_augustus_assyria_64.png</Item>
          <!-- Leader icons (civ-specific: carthage) -->
          <Item>icons/augustus/carthage/lp_circ_augustus_carthage_128.png</Item>
