          <Item>icons/augustus/aksum/lp_hex_augustus_aksum_256.png</Item>
          <Item>icons/augustus/aksum/lp_hex_augustus_aksum_64.png</Item>
          <!-- Leader icons (civ-specific: assyria) -->
