          <!-- UIScript for civ-specific icon swapping -->
          <Item>scripts/authentic-leaders-icons.js</Item>
        </ImportFiles>
        <UpdateDatabase>
          <Item>data/loading-info-override.sql</Item>
        </UpdateDatabase>
        <UpdateIcons>
